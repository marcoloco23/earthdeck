# overview-mcp environment — copy to .env (gitignored) or set these in your MCP client config.
# The zero-key tools (eo_snapshot, events, geo_resolve) work with none of these set.

# NASA FIRMS map key — needed for `fires_in`.
# Free, instant: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Copernicus Data Space OAuth client — needed for eo_render / eo_index / eo_search / eo_compare.
# Free: dataspace.copernicus.eu -> Dashboard -> User Settings -> OAuth clients (copy the
# secret immediately; pick "Never expire" or rotate every 90 days).
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# Dashboard (optional). Tools push result "cards" here best-effort; if it's not running,
# the tools still work normally.
OVERVIEW_DASHBOARD_PORT=5005
# OVERVIEW_DASHBOARD_URL=http://127.0.0.1:5005
