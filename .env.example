# earthdeck environment — copy to .env (gitignored) or set these in your MCP client config.
# The zero-key tools (eo_snapshot, events, geo_resolve, stac_search) work with none set.

# NASA FIRMS map key — needed for `fires_in`.
# Free, instant: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Copernicus Data Space OAuth client — needed for eo_render / eo_index / eo_search / eo_compare.
# Free: dataspace.copernicus.eu -> Dashboard -> User Settings -> OAuth clients (copy the
# secret immediately; pick "Never expire" or rotate every 90 days).
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# Global Forest Watch Data API key — needed for `forest_alerts` (integrated deforestation
# alerts). Free: create a GFW account, then mint a key:
# https://www.globalforestwatch.org/help/developers/guides/create-and-use-an-api-key/
GFW_API_KEY=

# Open STAC endpoint for `stac_search` (optional). Defaults to Earth Search (no key).
# Override to use Microsoft Planetary Computer or a self-hosted STAC.
# EARTHDECK_STAC_URL=https://earth-search.aws.element84.com/v1

# Dashboard (optional). Tools push result "cards" here best-effort; if it's not running,
# the tools still work normally.
EARTHDECK_DASHBOARD_PORT=5005
# EARTHDECK_DASHBOARD_URL=http://127.0.0.1:5005
