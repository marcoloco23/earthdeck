{
  "name": "earthdeck",
  "version": "0.3.1",
  "description": "The Earth-system data layer: an MCP server + live mission-control dashboard over free, open data. Satellite imagery, NDVI, SAR flood mapping, wildfires, El Niño tracking, ocean temperatures, CO₂, the global temperature record, sea ice, earthquakes, air quality, climate history — with trends, charts, and provenance. Zero-key demo: `npx earthdeck demo`.",
  "license": "MIT",
  "author": "marcoloco23",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcoloco23/earthdeck.git"
  },
  "homepage": "https://github.com/marcoloco23/earthdeck#readme",
  "bugs": "https://github.com/marcoloco23/earthdeck/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "earth",
    "satellite",
    "earth-observation",
    "remote-sensing",
    "sentinel",
    "copernicus",
    "nasa",
    "noaa",
    "climate",
    "el-nino",
    "enso",
    "co2",
    "sea-ice",
    "earthquakes",
    "ndvi",
    "sar",
    "wildfire",
    "dashboard"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "earthdeck": "dist/cli.js",
    "overview-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:web": "vite build",
    "dev": "tsx src/cli.ts",
    "dev:dashboard": "tsx src/cli.ts dashboard",
    "dev:web": "vite",
    "start": "node dist/cli.js",
    "dashboard": "node dist/cli.js dashboard",
    "prepare": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "node --import tsx --test test/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "maplibre-gl": "5.8.0",
    "tsx": "4.22.2",
    "typescript": "6.0.3",
    "vite": "7.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
